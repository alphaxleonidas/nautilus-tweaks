#!/bin/bash

# --- Configuration ---
API_KEY="whateverapikey"
BASE_URL="https://www.virustotal.com/api/v3"
# --- End Configuration ---

# Get the selected file path
FILE_PATH="$1"
if [ ! -f "$FILE_PATH" ]; then
    echo "Error: No valid file selected."
    exit 1
fi

# Calculate SHA-256 hash
HASH=$(sha256sum "$FILE_PATH" | awk '{print $1}')
echo "Checking VirusTotal for hash: $HASH"

# Query the API
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
    --request GET \
    --url "$BASE_URL/files/$HASH" \
    --header "x-apikey: $API_KEY")

if [ "$HTTP_CODE" -eq 200 ]; then
    echo "Report found. Opening result page..."
    xdg-open "https://www.virustotal.com/gui/file/$HASH"

# Upload if file not scanned before. CAUTION: It will upload your sensitive documents which can be viewed by anyone.
#elif [ "$HTTP_CODE" -eq 404 ]; then
#    echo "File not found, uploading for scanning..."
#    curl --request POST \
#        --url "$BASE_URL/files" \
#        --header "x-apikey: $API_KEY" \
#        --form "file=@$FILE_PATH"
#    echo "Upload complete. Opening result page..."
#    xdg-open "https://www.virustotal.com/gui/file/$HASH"

else
    gnome-terminal -- bash -c 'echo "file not found"; exec bash'
fi
